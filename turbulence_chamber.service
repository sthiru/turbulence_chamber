[Unit]
Description=Turbulence Chamber Service
After=network.target
StartLimitIntervalSec=0
[Service]
Type=simple
WorkingDirectory=/home/turbulence-chamber/Documents/turbulence_chamber/server/
Restart=always
RestartSec=1
User=turbulence-chamber
ExecStart=/home/turbulence-chamber/Documents/turbulence_chamber/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000

[Install]
WantedBy=multi-user.target